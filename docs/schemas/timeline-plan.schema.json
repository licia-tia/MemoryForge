{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memoryforge.local/schemas/timeline-plan.schema.json",
  "title": "TimelinePlan",
  "type": "object",
  "required": ["preset", "timeline", "rejected_notes", "editing_notes"],
  "properties": {
    "preset": { "type": "string", "minLength": 1 },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "source_type",
          "record_in_sec",
          "duration_sec",
          "source_asset_id",
          "role",
          "reason"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "enum": ["video", "photo"] },
          "record_in_sec": { "type": "number", "minimum": 0 },
          "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
          "source_asset_id": { "type": "string", "minLength": 1 },
          "source_in_sec": { "type": "number", "minimum": 0 },
          "source_out_sec": { "type": "number", "minimum": 0 },
          "role": { "type": "string" },
          "motion": { "type": "string" },
          "placement": { "type": "object", "additionalProperties": true },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "rejected_notes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "editing_notes": { "type": "string" }
  },
  "additionalProperties": false
}
