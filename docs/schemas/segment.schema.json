{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memoryforge.local/schemas/segment.schema.json",
  "title": "Segment",
  "type": "object",
  "required": [
    "segment_id",
    "asset_id",
    "source_in_sec",
    "source_out_sec",
    "captured_start_utc",
    "keyframes",
    "audio_features"
  ],
  "properties": {
    "segment_id": { "type": "string", "minLength": 1 },
    "asset_id": { "type": "string", "minLength": 1 },
    "source_in_sec": { "type": "number", "minimum": 0 },
    "source_out_sec": { "type": "number", "minimum": 0 },
    "captured_start_utc": { "type": ["string", "null"], "format": "date-time" },
    "keyframes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "audio_features": {
      "type": "object",
      "required": ["silent_ratio", "peak_db", "speech_detected"],
      "properties": {
        "silent_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "peak_db": { "type": ["number", "null"] },
        "speech_detected": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
